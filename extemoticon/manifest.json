{
  "manifest_version": 3,
  "name": "Sentiment Heatmap",
  "version": "2.0",
  "description": "Colors YouTube comments by sentiment",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://router.huggingface.co/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}